# Secret required in the X-API-Key header to create/list/inspect URLs.
API_KEY=dev-secret-key-change-me

# SQLAlchemy database URL.
DATABASE_URL=sqlite:///./shortener.db

# Public base URL used to build full short links in responses.
BASE_URL=http://localhost:8000

# Length of generated short codes.
CODE_LENGTH=6

# Comma-separated origins allowed to call the API (your frontend).
CORS_ORIGINS=http://localhost:3000
